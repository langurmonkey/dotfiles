#!/usr/bin/env bash

# Unicode ramp
ramp_arr=(‚ñÅ ‚ñÇ ‚ñÉ ‚ñÑ ‚ñÖ ‚ñÜ ‚ñá ‚ñà)

sar -P ALL 1 1 |
awk '
/^Average:[[:space:]]+[0-9]+/ {
    usage = 100 - $NF          # %idle is the last column
    idx = int((usage / 100) * 7 + 0.5)

    if (idx < 0) idx = 0
    if (idx > 7) idx = 7

    print idx
}
' |
while read -r idx; do
    printf "%s" "${ramp_arr[$idx]}"
done

echo
